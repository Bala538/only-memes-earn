# Port to run the server on
PORT=3000

# Allowed CORS Origins (separate with commas)
ALLOWED_ORIGINS=https://onlymemesearn.store,https://www.onlymemesearn.store,http://localhost:3000,http://localhost:5173

# SMTP Nodemailer Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM_EMAIL=noreply@onlymemesearn.store
SMTP_FROM_NAME=OnlyMemes Earn Support

# Firebase Service Account JSON payload (minified JSON string)
# Get this from Firebase Console -> Project Settings -> Service accounts
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "YOUR_PROJECT_ID", ...}
