rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function userExists(email) { return exists(/databases/$(database)/documents/users/$(email)); }
    function getUserData(email) { return get(/databases/$(database)/documents/users/$(email)).data; }
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token != null &&
             request.auth.token.get('email', null) != null &&
             userExists(request.auth.token.get('email', '')) &&
             getUserData(request.auth.token.get('email', '')).get('isAdmin', false) == true;
    }
    function isOwner(email) { 
      return isSignedIn() && (
        request.auth.uid == email ||
        (request.auth.token != null && request.auth.token.get('email', null) == email) ||
        (resource != null && resource.data.get('uid', '') == request.auth.uid) ||
        (resource == null && request.resource.data.get('uid', '') == request.auth.uid)
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Rules ---
    match /users/{email} {
      allow get: if isOwner(email) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && (
        resource.data.referredByEmail == request.auth.token.get('email', null) ||
        resource.data.referralCode != null
      ));
      
      function isValidUser(data) {
        return data.get('email', '') is string && 
               data.get('balance', {}) is map;
      }

      allow create: if isOwner(email) && isValidUser(request.resource.data);

      allow update: if (isOwner(email) || isAdmin()) && isValidUser(request.resource.data);

      allow delete: if isAdmin();
    }

    // --- Market Rules ---
    match /markets/{marketId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Videos and Games Rules ---
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Task Rules ---
    match /youtubeTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /telegramTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /facebookTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /instagramTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /twitterTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /tiktokTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /appDownloadTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /otherTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }

    // --- Global Configs & Banners ---
    match /banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /configs/{id} { allow read: if true; allow write: if isAdmin(); }
    match /promoCodes/{id} { allow read: if true; allow write: if isAdmin(); }
    match /mineUpgrades/{id} { allow read: if true; allow write: if isAdmin(); }

    // --- Admin Logs ---
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
