rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function getUserData(email) { return get(/databases/$(database)/documents/users/$(email)).data; }
    function isAdmin() { return isSignedIn() && getUserData(request.auth.token.email).isAdmin == true; }
    function isOwner(email) { return isSignedIn() && request.auth.token.email == email; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- User Rules ---
    match /users/{email} {
      allow get: if isOwner(email) || isAdmin();
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.email is string && 
               data.email.size() <= 100 &&
               data.balance is map &&
               (data.balance.keys().size() <= 20) &&
               (data.isAdmin == false || isAdmin()) &&
               (data.isBlocked == false || isAdmin());
      }

      allow create: if isOwner(email) && isValidUser(incoming()) && (
        incoming().isAdmin == false && 
        incoming().balance.keys().size() == 0
      );

      allow update: if isOwner(email) && isValidUser(incoming()) && (
        // Action: Update profile (no balance/admin change)
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'fcmToken'])) ||
        // Action: Submit Task Proof (append to array)
        (incoming().diff(existing()).affectedKeys().hasOnly(['taskProofs']) && 
         incoming().taskProofs.size() > existing().get('taskProofs', []).size()) ||
        // Action: Trade Execution (special case for balance updates)
        // Note: Ideally this should check if the change matches an order matched in a market
        (incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'openOrders']))
      ) || isAdmin();
    }

    // --- Market Rules ---
    match /markets/{marketId} {
      allow read: if true;
      
      function isValidMarket(data) {
        return data.base is string && data.quote is string &&
               data.price is number && data.price >= 0;
      }

      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Action: Execute Trade (Self-limiting)
        isSignedIn() && isValidMarket(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['bids', 'asks', 'trades', 'price', 'candles', 'volume'])
      );
    }

    // --- Task Rules (Read Only for Users) ---
    match /youtubeTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /telegramTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /facebookTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /instagramTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /twitterTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /tiktokTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /appDownloadTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }
    match /otherTasks/{taskId} { allow read: if true; allow write: if isAdmin(); }

    // --- Global Configs & Banners ---
    match /banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /configs/{id} { allow read: if true; allow write: if isAdmin(); }
    match /promoCodes/{id} { allow read: if true; allow write: if isAdmin(); }
    match /mineUpgrades/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
